/**
 * @fileoverview Firestore Security Rules for HopeEngineer Hub.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model for user profiles
 * and public read access with restricted write access for blog posts.
 * Contact messages are publicly writable but only readable by admins.
 *
 * Data Structure:
 * - /users/{userId}: Stores user profile data.
 * - /blogPosts/{postId}: Stores blog posts.
 * - /contacts/{contactId}: Stores contact messages.
 *
 * Key Security Decisions:
 * - Users can only read/write their own profile data.
 * - Blog posts are publicly readable.
 * - Only authenticated users (admins) can create, update, or delete blog posts.
 * - Anyone can create a contact message, but only admins can read them.
 * - No user listing is allowed.
 *
 * Denormalization for Authorization:
 *  N/A - current rules do not require denormalization
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Controls access to user profile information.
     * @path /users/{userId}
     * @allow (create) User with ID 'user123' can create their profile.
     * @allow (get, update, delete) User with ID 'user123' can read and modify their own profile.
     * @deny (get, update, delete) User with ID 'user456' cannot access user 'user123' profile.
     * @principle Enforces document ownership for writes.
     */
    match /users/{userId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      function isExistingOwner(userId) {
        return request.auth.uid == resource.data.uid;
      }

      allow get: if isSignedIn() && isOwner(userId);
      allow list: if false;
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && isOwner(userId);
      allow delete: if isSignedIn() && isOwner(userId);
    }

    /**
     * @description Controls access to blog posts.
     * @path /blogPosts/{postId}
     * @allow (get, list) Any user can read/list blog posts.
     * @allow (create, update, delete) Only authenticated users can modify blog posts.
     * @deny (create, update, delete) Unauthenticated users cannot modify blog posts.
     * @principle Public read, restricted write access with owner-only updates.
     */
    match /blogPosts/{postId} {
      allow get: if true;
      allow list: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Controls access to contact messages.
     * @path /contacts/{contactId}
     * @allow (create) Any user can submit a contact message.
     * @deny (get, list, update, delete) Only authenticated users can read contact messages.
     * @principle Public write, restricted read access.
     */
    match /contacts/{contactId} {
      allow get: if isSignedIn();
      allow list: if false;
      allow create: if true;
      allow update: if false;
      allow delete: if false;
    }
  }
}