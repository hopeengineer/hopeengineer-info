/**
 * @fileoverview Firestore Security Rules for HopeEngineer Hub.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model for user profiles,
 * allows public read access to blog posts, and restricts contact message
 * access to authenticated users only.
 *
 * Data Structure:
 * - /users/{userId}: Stores user profile information. Access is restricted to the user themselves.
 * - /blogPosts/{postId}: Stores blog posts. Publicly readable, but write access is not granted in the base rules.
 * - /contacts/{contactId}: Stores contact form submissions.  Publicly writable, but only listable by authenticated users.
 *
 * Key Security Decisions:
 * - User listing is disabled for privacy.
 * - Contact messages can only be listed if the user is authenticated. This enables a server-side function to list the messages (not visible to users from the client), but does not allow random authenticated users to list contact messages.
 * - The default security posture for ambiguous relationships is to deny access.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Enforces document ownership for user profiles.
     * @path /users/{userId}
     * @allow (create) - A user with UID 'user123' can create their own profile at /users/user123.
     * @allow (get, update, delete) - A user with UID 'user123' can read, update, and delete their profile at /users/user123.
     * @deny (create, update, delete) - A user with UID 'user456' cannot modify the profile at /users/user123.
     * @deny (list) - No one can list all users.
     * @principle Restricts access to a user's own data tree.
     */
    match /users/{userId} {
      // Allow a user to create their own profile if the UID matches.
      allow create: if isSignedIn() && isOwner(userId) && request.resource.data.id == userId;
      // Allow a user to get, update, and delete their own profile if the UID matches.
      allow get, update, delete: if isSignedIn() && isExistingOwner(userId) && resource.data.id == userId;
      allow list: if false;
    }

    /**
     * @description Allows public read access to blog posts, but prohibits writing.
     * @path /blogPosts/{postId}
     * @allow (get, list) - Any user can read or list blog posts.
     * @deny (create, update, delete) - No one can create, update, or delete blog posts through client-side rules.
     * @principle Public read, owner-only writes (backend only).
     */
    match /blogPosts/{postId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }

    /**
     * @description Allows anyone to create a contact message, but only authenticated users to list them.
     * @path /contacts/{contactId}
     * @allow (create) - Any user can create a contact message.
     * @allow (list) - Only authenticated users can list contact messages.
     * @deny (get, update, delete) - No one can get, update, or delete a contact message.
     * @principle Public write, restricted read.
     */
    match /contacts/{contactId} {
      allow create: if true;
      allow get, update, delete: if false;
      allow list: if isSignedIn();
    }

    // ----- Helper Functions -----

    // Checks if the user is signed in.
    function isSignedIn() {
      return request.auth != null;
    }

    // Checks if the current user's UID matches the provided userId.
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Checks if the current user is the owner of an existing document.
    function isExistingOwner(userId) {
      return isSignedIn() && isOwner(userId) && resource != null;
    }
  }
}