/**
 * @fileoverview Firestore Security Rules for HopeEngineer Hub.
 *
 * Core Philosophy:
 * This ruleset implements a hybrid security model. User data is strictly protected
 * under path-based ownership in the `/users/{userId}` collection. Blog posts are
 * publicly readable but only writable by authorized users (e.g., admins). Contact
 * messages can be created by anyone but are only readable by admins.
 *
 * Data Structure:
 * - /users/{userId}: Stores personal user data, accessible only by the user.
 * - /blogPosts/{postId}: Stores blog posts. Publicly readable, admin-only writeable.
 * - /contacts/{contactId}: Stores contact form submissions. Publicly writable, admin-only readable.
 *
 * Key Security Decisions:
 * - User listing is disallowed.
 * - The 'contacts' collection is configured for public writes and admin-only reads.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Secures user profile data.
     * @path /users/{userId}
     * @allow (create) - User can create their own profile if the userId matches their auth UID.
     * @allow (get, update, delete, list) - User can only access their own profile.
     * @deny (create) - User cannot create a profile with an ID that doesn't match their auth UID.
     * @deny (get, update, delete, list) - User cannot access other user profiles.
     * @principle Enforces document ownership for all operations.
     */
    match /users/{userId} {
      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      function isSignedIn() {
        return request.auth != null;
      }

      allow get: if isOwner(userId);
      allow list: if false;

      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    /**
     * @description Secures blog post data.
     * @path /blogPosts/{postId}
     * @allow (get, list) - All users can read blog posts.
     * @allow (create, update, delete) - Only authorized users (e.g., admins) can modify blog posts.
     * @deny (create, update, delete) - Unauthorized users cannot modify blog posts.
     * @principle Allows public reads but restricts writes to authorized users.
     */
    match /blogPosts/{postId} {
      allow get, list: if true;
      allow create, update, delete: if false; // TODO: Add admin role check.
    }

    /**
     * @description Secures contact messages.
     * @path /contacts/{contactId}
     * @allow (create) - All users can submit contact messages.
     * @allow (get, list) - Only authorized users (e.g., admins) can read contact messages.
     * @deny (get, list) - Unauthorized users cannot read contact messages.
     * @deny (update, delete) - Contact messages cannot be updated or deleted once created.
     * @principle Allows public writes but restricts reads to authorized users.
     */
    match /contacts/{contactId} {
      allow get, list: if false; // TODO: Add admin role check.
      allow create: if true;
      allow update, delete: if false;
    }
  }
}