/**
 * @fileoverview Firestore Security Rules for HopeEngineer Hub.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model for user profiles,
 * allows public read access to blog posts, restricts blog post writes to admins,
 * and allows public writes to contact messages while restricting reads to admins.
 *
 * Data Structure:
 * - /users/{userId}: Stores individual user profiles.  The {userId} must match
 *   the authenticated user's UID.
 * - /blogPosts/{postId}: Stores blog posts. Read access is public, but write
 *   access is restricted to admins.
 * - /contacts/{contactId}: Stores contact form submissions.  Write access is
 *   public, but read access is restricted to admins.
 *
 * Key Security Decisions:
 * - User listing is disallowed.
 * - Contact messages can be created by anyone, even unauthenticated users.
 * - There are no explicit admin roles defined; all collections are locked down except for blogPosts and contacts.
 *
 *
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Protects user profiles under /users/{userId}.
     * @path /users/{userId}
     * @allow (create) User H12wy261F2Roi6eETsaSs3zxxZC2 can create their profile with matching id.
     * @allow (get, update, delete, list) User H12wy261F2Roi6eETsaSs3zxxZC2 can get their own profile.
     * @deny (create) User H12wy261F2Roi6eETsaSs3zxxZC2 cannot create a profile with a mismatched id.
     * @deny (get, update, delete, list) User H12wy261F2Roi6eETsaSs3zxxZC2 cannot access another user's profile.
     * @principle Enforces document ownership for all operations.
     */
    match /users/{userId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }

      function isExistingOwner(userId) {
          return isOwner(userId) && resource != null;
      }

      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Manages access to blog posts under /blogPosts/{postId}.
     * @path /blogPosts/{postId}
     * @allow (get, list) Any user can read blog posts.
     * @deny (create, update, delete) No access is given.
     * @principle Allows public read access but restricts writes.
     */
    match /blogPosts/{postId} {
      allow get, list: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Controls access to contact messages under /contacts/{contactId}.
     * @path /contacts/{contactId}
     * @allow (create) Any user can submit a contact message.
     * @deny (get, list, update, delete) No access is given.
     * @principle Allows public write access but restricts reads.
     */
    match /contacts/{contactId} {
      allow get, list: if false;
      allow create: if true;
      allow update: if false;
      allow delete: if false;
    }
  }
}