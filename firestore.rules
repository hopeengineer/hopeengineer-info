/**
 * @fileoverview Firestore Security Rules for HopeEngineer Hub.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model for user profiles,
 * allows public read access to blog posts, restricts blog post writes to admins,
 * and allows anyone to create contact messages, but limits access to those messages to admins only.
 *
 * Data Structure:
 * - /users/{userId}: Stores user profile information. Access is restricted to the user themselves.
 * - /blogPosts/{postId}: Stores blog posts. Publicly readable, but only writable by admins.
 * - /contacts/{contactId}: Stores contact messages. Publicly writable, but only readable by admins.
 *
 * Key Security Decisions:
 * - User listing is explicitly denied.
 * - Admin role management is not implemented in this prototype, instead all write operations are denied.
 *
 * Denormalization for Authorization:
 *  - No denormalization is explicitly used.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Controls access to user profile information.
     * @path /users/{userId}
     * @allow (create) User with matching ID can create their profile.
     * @allow (get, list, update, delete) User with matching ID can read, update, and delete their profile.
     * @deny (create) User tries to create a profile with an ID that doesn't match their auth UID.
     * @deny (get, list, update, delete) User tries to access another user's profile.
     * @principle Enforces document ownership for all operations.
     */
    match /users/{userId} {
      //Function to check if the user is signed in
      function isSignedIn() {
        return request.auth != null;
      }

      //Function to check if the user id matches the authenticated user's id
      function isOwner(userId) {
        return isSignedIn() && request.auth.uid == userId;
      }

      // Function to check if the user is the existing owner
      function isExistingOwner(userId) {
          return isSignedIn() && request.auth.uid == userId && resource.data != null;
      }

      allow get: if isOwner(userId);
      allow list: if false; // Listing all users is not permitted

      // Allow the user to create their own document, but no one else's
      allow create: if isSignedIn() && isOwner(userId);

      allow update: if isExistingOwner(userId);

      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Controls access to blog post documents.
     * @path /blogPosts/{postId}
     * @allow (get, list) All users can read blog posts.
     * @deny (create, update, delete) Only admins can modify blog posts.
     * @principle Public read access with restricted writes.
     */
    match /blogPosts/{postId} {
      allow get, list: if true;
      allow create, update, delete: if false; // TODO: Add admin role check.
    }

    /**
     * @description Controls access to contact form submissions.
     * @path /contacts/{contactId}
     * @allow (create) All users can submit contact form messages.
     * @deny (get, list, update, delete) Only admins can read contact form messages.
     * @principle Public write access with restricted reads.
     */
    match /contacts/{contactId} {
      allow create: if true;
      allow get, list, update, delete: if false; // TODO: Add admin role check.
    }
  }
}