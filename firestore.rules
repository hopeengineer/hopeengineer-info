/**
 * @fileoverview Firestore Security Rules for HopeEngineer Hub.
 *
 * Core Philosophy:
 * This ruleset prioritizes a clear separation of concerns: user data is strictly controlled by the owning user, while blog posts are publicly readable but only writable by authorized users (e.g., admins).
 *
 * Data Structure:
 * - /users/{userId}: Stores individual user profiles. Each user can only access their own profile data.
 * - /blogPosts/{postId}: Stores blog posts. These are publicly readable.
 *
 * Key Security Decisions:
 * - User profiles are private and accessible only to the owning user.
 * - Blog posts are publicly readable to enable wide content distribution.
 * - Only authorized users can create, update, or delete blog posts.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Controls access to user profile data.
     * @path /users/{userId}
     * @allow (create) User with matching ID can create their own profile.
     * @allow (get, update, delete) User can access their own profile.
     * @deny (create) User cannot create a profile with an ID that doesn't match their own.
     * @deny (get, update, delete) User cannot access another user's profile.
     * @principle Enforces document ownership for writes.
     */
    match /users/{userId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      function isExistingOwner(userId) {
        return isSignedIn() && isOwner(userId) && resource.data != null;
      }

      allow get: if isSignedIn() && isOwner(userId);
      allow list: if false;
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Controls access to blog post data.
     * @path /blogPosts/{postId}
     * @allow (get, list) Any user can read blog posts.
     * @deny (create, update, delete) Only admins can create, update, or delete blog posts.
     * @principle Public read with restricted writes.
     */
    match /blogPosts/{postId} {
      allow get, list: if true;
      allow create, update, delete: if false; // TODO: Add admin role check
    }
  }
}