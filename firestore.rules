/**
 * @fileoverview Firestore Security Rules for HopeEngineer Hub.
 *
 * Core Philosophy:
 * This ruleset enforces a user-ownership model for user profiles and restricts access to contact messages and blog posts.
 *
 * Data Structure:
 * - /users/{userId}: Stores user profile data, accessible only by the user themselves.
 * - /blogPosts/{postId}: Stores blog posts, publicly readable but writable only by admins (not yet implemented due to lack of admin role definition).
 * - /contacts/{contactId}: Stores contact form submissions, publicly writable, but only readable by admins (not yet implemented due to lack of admin role definition).
 *
 * Key Security Decisions:
 * - User listing is disallowed.
 * - Admin roles are not yet implemented, so admin-only permissions are placeholders.
 * - Data shape validation is minimal to allow for rapid prototyping.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Controls access to user profile information.
     * @path /users/{userId}
     * @allow (create) User with ID 'H12wy261F2Roi6eETsaSs3zxxZC2' can create their own profile.
     * @deny (create) User with ID 'otherUserId' cannot create a profile for 'H12wy261F2Roi6eETsaSs3zxxZC2'.
     * @allow (get, list, update, delete) User with ID 'H12wy261F2Roi6eETsaSs3zxxZC2' can read and modify their own profile.
     * @deny (get, list, update, delete) User with ID 'otherUserId' cannot read or modify profile 'H12wy261F2Roi6eETsaSs3zxxZC2'.
     * @principle Enforces document ownership, restricting access to a user's own data.
     */
    match /users/{userId} {
      // Allow the user to read/write their own profile
      allow get: if isSignedIn() && isOwner(userId);
      allow list: if false; // disable listing all users.
      allow create: if isSignedIn() && isOwner(userId) && request.resource.data.id == userId;
      allow update: if isSignedIn() && isExistingOwner(userId) && request.resource.data.id == resource.data.id; // immutable id
      allow delete: if isSignedIn() && isExistingOwner(userId);
    }

    /**
     * @description Controls access to blog posts.
     * @path /blogPosts/{postId}
     * @allow (get, list) Any user can read the blog posts.
     * @deny (create, update, delete) Non-admin users cannot create, update, or delete blog posts.
     * @principle Public read access with restricted write access.
     */
    match /blogPosts/{postId} {
      allow get, list: if true;
      allow create, update, delete: if false; // TODO: Add admin validation once the schema is updated with an ownership field.
    }

    /**
     * @description Controls access to contact messages.
     * @path /contacts/{contactId}
     * @allow (create) Any user can submit a contact message.
     * @deny (get, list, update, delete) Non-admin users cannot read, update, or delete contact messages.
     * @principle Public write access with restricted read access.
     */
    match /contacts/{contactId} {
      allow get, list: if false; // TODO: Implement admin role check
      allow create: if true;
      allow update, delete: if false; // Only admins should be able to do this

    }

    // ---- Helper functions ---

    /**
     * @description Checks if the user is signed in.
     * @return {boolean} True if the user is signed in, false otherwise.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the requesting user is the owner of the document.
     * @param {string} userId The user ID to check against.
     * @return {boolean} True if the user is the owner, false otherwise.
     */
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    /**
     * @description Checks if the requesting user is the owner of the existing document.
     * @param {string} userId The user ID to check against.
     * @return {boolean} True if the user is the owner and the resource exists, false otherwise.
     */
    function isExistingOwner(userId) {
        return isSignedIn() && isOwner(userId) && resource != null;
    }
  }
}